{
  "manifest_version": 3,
  "name": "AURA Connector",
  "version": "1.0",
  "description": "Connects ChatGPT, Grok, and other AIs to your local AURA Avatar.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://chatgpt.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AURA Connector"
  }
}
